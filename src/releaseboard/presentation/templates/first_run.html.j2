<!DOCTYPE html>
<html lang="{{ locale }}" data-theme="light">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>ReleaseBoard — Setup</title>
<script>
/* i18n — locale persistence: redirect to stored locale if no explicit ?lang= */
(function() {
  var stored = localStorage.getItem('rb_locale');
  if (stored && !new URLSearchParams(window.location.search).has('lang')) {
    var url = new URL(window.location.href);
    url.searchParams.set('lang', stored);
    window.location.replace(url.toString());
  }
})();
</script>
<style>
/* ── Design tokens (light) ── */
:root {
  --primary: #fb6400;
  --primary-hover: #e55500;
  --primary-light: #fb640015;
  --ring: #fb640033;
  --radius: 10px;
  --radius-sm: 6px;
  --radius-xs: 4px;
  --radius-md: 12px;
  --shadow-sm: 0 1px 2px rgba(0,0,0,.04);
  --shadow: 0 1px 3px rgba(0,0,0,.08), 0 1px 2px rgba(0,0,0,.04);
  --shadow-md: 0 4px 6px rgba(0,0,0,.06), 0 2px 4px rgba(0,0,0,.04);
  --shadow-lg: 0 10px 25px rgba(0,0,0,.08), 0 4px 10px rgba(0,0,0,.04);
  --font: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
  --font-mono: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
  --bg-primary: #ffffff;
  --bg-secondary: #f8fafc;
  --bg-tertiary: #f1f5f9;
  --bg-card: #ffffff;
  --bg-hover: #f1f5f9;
  --bg-input: #ffffff;
  --border: #e2e8f0;
  --border-light: #f1f5f9;
  --text-primary: #0f172a;
  --text-secondary: #475569;
  --text-tertiary: #94a3b8;
  --text-muted: #64748b;
  --transition: 180ms ease;
  --font-size-sm: 12px;
}
/* ── Dark theme ── */
[data-theme="dark"] {
  --bg-primary: #0f172a; --bg-secondary: #1e293b; --bg-tertiary: #334155;
  --bg-card: #1e293b; --bg-hover: #334155; --bg-input: #1e293b;
  --border: #334155; --border-light: #1e293b;
  --text-primary: #f1f5f9; --text-secondary: #94a3b8; --text-tertiary: #64748b;
  --text-muted: #94a3b8; --ring: #fb640044;
}
/* ── Midnight theme ── */
[data-theme="midnight"] {
  --primary-light: #fb640018;
  --bg-primary: #0c0e14; --bg-secondary: #12151e; --bg-tertiary: #1a1e2e;
  --bg-card: #141722; --bg-hover: #1e2236; --bg-input: #12151e;
  --border: #232840; --border-light: #1a1e2e;
  --text-primary: #e8ecf4; --text-secondary: #9dabc2; --text-tertiary: #7484a0;
  --text-muted: #8da0b8; --ring: #fb640033;
  --shadow-sm: 0 1px 2px rgba(0,0,0,.2);
  --shadow: 0 1px 3px rgba(0,0,0,.3), 0 1px 2px rgba(0,0,0,.2);
  --shadow-md: 0 4px 8px rgba(0,0,0,.25), 0 2px 4px rgba(0,0,0,.15);
  --shadow-lg: 0 12px 32px rgba(0,0,0,.4), 0 4px 8px rgba(0,0,0,.2);
}
/* ── System theme (follows OS preference) ── */
@media (prefers-color-scheme: dark) {
  [data-theme="system"] {
    --bg-primary: #0f172a; --bg-secondary: #1e293b; --bg-tertiary: #334155;
    --bg-card: #1e293b; --bg-hover: #334155; --bg-input: #1e293b;
    --border: #334155; --border-light: #1e293b;
    --text-primary: #f1f5f9; --text-secondary: #94a3b8; --text-tertiary: #64748b;
    --text-muted: #94a3b8; --ring: #fb640044;
  }
}

/* ── Reset ── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: var(--font);
  background: var(--bg-secondary);
  color: var(--text-primary);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}
a { color: var(--primary); text-decoration: none; }
a:hover { text-decoration: underline; }

/* ── Header (shared shell pattern) ── */
.fr-header {
  background: var(--bg-card);
  border-bottom: 1px solid var(--border);
  padding: 0 24px;
  position: sticky;
  top: 0;
  z-index: 100;
}
.fr-header-inner {
  max-width: 960px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 0;
  gap: 16px;
}
.fr-header-logo { display: flex; align-items: center; flex-shrink: 0; }
.fr-header-logo svg { height: 50px; width: auto; }
/* Logo theme variants — use .fr-header-logo prefix for specificity > 0,1,1 */
.fr-header-logo .fr-logo-light { display: block; }
.fr-header-logo .fr-logo-dark,
.fr-header-logo .fr-logo-midnight { display: none; }
[data-theme="dark"] .fr-header-logo .fr-logo-light { display: none; }
[data-theme="dark"] .fr-header-logo .fr-logo-dark { display: block; }
[data-theme="midnight"] .fr-header-logo .fr-logo-light { display: none; }
[data-theme="midnight"] .fr-header-logo .fr-logo-midnight { display: block; }
@media (prefers-color-scheme: dark) {
  [data-theme="system"] .fr-header-logo .fr-logo-light { display: none; }
  [data-theme="system"] .fr-header-logo .fr-logo-dark { display: block; }
}
.fr-header-controls {
  display: flex;
  align-items: center;
  gap: 8px;
}

/* ── Settings trigger (gear icon) ── */
.fr-settings-wrap { position: relative; }
.fr-settings-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  border-radius: var(--radius-sm);
  border: 1px solid var(--border);
  background: var(--bg-card);
  color: var(--text-secondary);
  cursor: pointer;
  font-size: 16px;
  transition: all var(--transition);
  flex-shrink: 0;
}
.fr-settings-btn:hover,
.fr-settings-wrap.open .fr-settings-btn {
  border-color: var(--primary);
  color: var(--primary);
  background: var(--primary-light);
}
.fr-settings-panel {
  display: none;
  position: absolute;
  top: calc(100% + 8px);
  right: 0;
  width: 280px;
  max-height: calc(100vh - 80px);
  overflow-y: auto;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-lg);
  z-index: 500;
  animation: frFadeIn .15s ease-out;
}
.fr-settings-wrap.open .fr-settings-panel { display: block; }
@keyframes frFadeIn { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: translateY(0); } }
.fr-settings-section {
  padding: 14px 16px;
  border-bottom: 1px solid var(--border);
}
.fr-settings-section:last-child { border-bottom: none; }
.fr-settings-title {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .06em;
  color: var(--text-tertiary);
  margin-bottom: 10px;
}

/* ── Shared button group (theme / language) ── */
.fr-btn-group {
  display: flex;
  gap: 0;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  overflow: hidden;
}
.fr-toggle-btn {
  padding: 5px 10px;
  font-size: 12px;
  font-weight: 500;
  font-family: var(--font);
  border: none;
  background: var(--bg-secondary);
  color: var(--text-secondary);
  cursor: pointer;
  transition: all var(--transition);
  white-space: nowrap;
}
.fr-toggle-btn + .fr-toggle-btn { border-left: 1px solid var(--border); }
.fr-toggle-btn:hover { background: var(--bg-hover); color: var(--text-primary); }
.fr-toggle-btn.active { background: var(--primary); color: #fff; font-weight: 600; }

/* ── Main content wrapper ── */
.fr-wrapper {
  max-width: 720px;
  margin: 0 auto;
  padding: 48px 24px 40px;
  flex: 1;
  width: 100%;
}

/* ── Hero ── */
.fr-hero { text-align: center; margin-bottom: 40px; }
.fr-hero h1 {
  font-size: 28px;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8px;
}
.fr-hero p {
  font-size: 15px;
  color: var(--text-secondary);
  max-width: 480px;
  margin: 0 auto 16px;
}
.fr-config-path {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: var(--bg-tertiary);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 6px 14px;
  font-size: 13px;
  color: var(--text-muted);
}
.fr-config-path code {
  font-family: var(--font-mono);
  color: var(--text-primary);
  font-weight: 500;
}

/* ── Option cards ── */
.fr-cards { display: flex; flex-direction: column; gap: 16px; margin-bottom: 40px; }
.fr-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 24px;
  box-shadow: var(--shadow);
  transition: border-color var(--transition), box-shadow var(--transition);
  cursor: pointer;
  position: relative;
}
.fr-card:hover { border-color: var(--primary); box-shadow: var(--shadow-md); }
.fr-card.active { border-color: var(--primary); box-shadow: 0 0 0 2px var(--primary-light), var(--shadow-md); }
.fr-card-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 8px;
}
.fr-card-icon {
  width: 40px;
  height: 40px;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  flex-shrink: 0;
}
.fr-card-icon.fresh { background: #fb640015; }
.fr-card-icon.wizard { background: #10b98115; }
.fr-card-icon.example { background: #3b82f615; }
.fr-card-icon.import { background: #8b5cf615; }
.fr-card-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
}
.fr-badge {
  display: inline-block;
  font-size: 10px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  background: var(--primary);
  color: #fff;
  padding: 2px 8px;
  border-radius: 10px;
  margin-left: 8px;
  vertical-align: middle;
}
.fr-card-desc {
  font-size: 13px;
  color: var(--text-secondary);
  margin-bottom: 0;
}

/* ── Expandable form bodies ── */
.fr-card-body {
  max-height: 0;
  overflow: hidden;
  transition: max-height 300ms ease, margin-top 300ms ease, opacity 200ms ease;
  opacity: 0;
  margin-top: 0;
}
.fr-card.active .fr-card-body {
  max-height: 600px;
  opacity: 1;
  margin-top: 20px;
}

/* ── Form elements ── */
.fr-form-group { margin-bottom: 14px; }
.fr-form-group:last-child { margin-bottom: 0; }
.fr-label {
  display: block;
  font-size: 12px;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 4px;
  text-transform: uppercase;
  letter-spacing: 0.3px;
}
.fr-input, .fr-select, .fr-textarea {
  width: 100%;
  padding: 8px 12px;
  font-family: var(--font);
  font-size: 14px;
  color: var(--text-primary);
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: var(--radius-xs);
  transition: border-color var(--transition), box-shadow var(--transition);
  outline: none;
}
.fr-input:focus, .fr-select:focus, .fr-textarea:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 3px var(--primary-light);
}
.fr-textarea {
  font-family: var(--font-mono);
  font-size: 12px;
  line-height: 1.5;
  resize: vertical;
  min-height: 140px;
}
.fr-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.fr-hint {
  font-size: 12px;
  color: var(--text-tertiary);
  margin-top: 8px;
  margin-bottom: 15px;
  line-height: 1.5;
}

/* ── Action buttons ── */
.fr-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 10px 20px;
  font-family: var(--font);
  font-size: 14px;
  font-weight: 600;
  border: none;
  border-radius: var(--radius-sm);
  cursor: pointer;
  transition: background var(--transition), transform 80ms ease;
  width: 100%;
}
.fr-btn:active { transform: scale(0.98); }
.fr-btn.primary { background: var(--primary); color: #fff; }
.fr-btn.primary:hover { background: var(--primary-hover); }
.fr-btn.primary:disabled { background: var(--text-tertiary); cursor: not-allowed; transform: none; }
.fr-btn.secondary { background: var(--bg-tertiary); color: var(--text-primary); border: 1px solid var(--border); }
.fr-btn.secondary:hover { background: var(--border-light); }

/* ── Examples list ── */
.fr-examples-list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px; }
.fr-example-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 14px;
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  border-radius: var(--radius-xs);
  cursor: pointer;
  transition: border-color var(--transition), background var(--transition);
}
.fr-example-item:hover { background: var(--bg-tertiary); border-color: var(--primary); }
.fr-example-item.selected { border-color: var(--primary); background: var(--primary-light); }
.fr-example-name { font-size: 14px; font-weight: 500; color: var(--text-primary); }
.fr-example-file { color: var(--text-tertiary); font-size: 12px; }
.fr-example-meta { font-size: 12px; color: var(--text-tertiary); }
.fr-no-examples { text-align: center; color: var(--text-tertiary); font-size: 13px; padding: 16px; }

/* ── Status messages ── */
.fr-message {
  padding: 10px 14px;
  border-radius: var(--radius-xs);
  font-size: 13px;
  margin-top: 12px;
  display: none;
}
.fr-message.error { display: block; background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; }
.fr-message.success { display: block; background: #f0fdf4; border: 1px solid #bbf7d0; color: #166534; }
.fr-message.info { display: block; background: #eff6ff; border: 1px solid #bfdbfe; color: #1e40af; }
[data-theme="dark"] .fr-message.error, [data-theme="midnight"] .fr-message.error { background: #450a0a; border-color: #7f1d1d; color: #fca5a5; }
[data-theme="dark"] .fr-message.success, [data-theme="midnight"] .fr-message.success { background: #052e16; border-color: #166534; color: #86efac; }
[data-theme="dark"] .fr-message.info, [data-theme="midnight"] .fr-message.info { background: #1e3a5f; border-color: #1e40af; color: #93c5fd; }

/* ── Footer (matches dashboard rb-footer) ── */
.rb-footer {
  border-top: 1px solid var(--border);
  margin-top: 40px;
  font-size: var(--font-size-sm, 12px);
  color: var(--text-tertiary);
  text-align: center;
  padding: 20px 0 24px;
  transition: border-color var(--transition);
}
.rb-footer-copyright { font-size: 13px; color: var(--text-secondary); margin-bottom: 6px; }
.rb-footer-tools { font-size: 12px; color: var(--text-tertiary); }
.rb-footer-brand { font-weight: 600; color: var(--text-secondary); text-decoration: none; }
.rb-footer-brand:hover { color: var(--primary); text-decoration: underline; }
.rb-footer-author { font-weight: 700; color: var(--text-secondary); text-decoration: none; letter-spacing: 0.5px; }
.rb-footer-author:hover { color: var(--primary); text-decoration: underline; }

/* ── Spinner ── */
.fr-spinner {
  display: inline-block;
  width: 14px;
  height: 14px;
  border: 2px solid rgba(255,255,255,0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: fr-spin 0.6s linear infinite;
}
@keyframes fr-spin { to { transform: rotate(360deg); } }

/* ── Responsive ── */
@media (max-width: 600px) {
  .fr-wrapper { padding: 32px 16px 32px; }
  .fr-hero h1 { font-size: 22px; }
  .fr-row { grid-template-columns: 1fr; }
  .fr-card { padding: 18px; }
  .fr-header-logo svg { height: 34px; }
  .fr-settings-panel { width: 240px; }
}
</style>
</head>
<body>

