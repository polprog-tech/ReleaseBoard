        <text x="270" y="56" font-family="system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="38" font-weight="700" fill="#fb6400">Board</text>
        <text x="120" y="82" font-family="system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="14" font-weight="400" fill="#94a3b8" letter-spacing="0.5">Release Readiness Intelligence</text>
      </svg>
      <!-- Midnight logo -->
      <svg class="fr-logo-midnight" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 410 112" fill="none" role="img" aria-label="ReleaseBoard">
        <defs><linearGradient id="hbg3" x1="0" y1="0" x2="120" y2="120" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="#fb6400"/><stop offset="100%" stop-color="#e55500"/></linearGradient><linearGradient id="hck3" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#fff"/><stop offset="100%" stop-color="#ffe0cc"/></linearGradient></defs>
        <rect x="8" y="12" width="96" height="96" rx="20" fill="url(#hbg3)"/>
        <path d="M40 36 L40 64 Q40 76 52 76 L72 76" stroke="url(#hck3)" stroke-width="5" stroke-linecap="round" fill="none"/>
        <path d="M40 48 Q40 56 50 56 L62 56" stroke="url(#hck3)" stroke-width="5" stroke-linecap="round" fill="none"/>
        <circle cx="40" cy="36" r="5" fill="#fff"/><circle cx="72" cy="76" r="5" fill="#fff"/><circle cx="62" cy="56" r="5" fill="#fff"/>
        <path d="M58 82 L66 90 L82 70" stroke="#fff" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round" fill="none" opacity="0.5"/>
        <text x="120" y="56" font-family="system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="38" font-weight="700" fill="#e8ecf4">Release</text>
        <text x="270" y="56" font-family="system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="38" font-weight="700" fill="#fb6400">Board</text>
        <text x="120" y="82" font-family="system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="14" font-weight="400" fill="#7484a0" letter-spacing="0.5">Release Readiness Intelligence</text>
      </svg>
    </div>
    <div class="fr-header-controls">
      <!-- Settings gear -->
      <div class="fr-settings-wrap" id="frSettings">
        <button class="fr-settings-btn" onclick="frToggleSettings()" aria-label="Quick settings" title="Settings">⚙</button>
        <div class="fr-settings-panel" onclick="event.stopPropagation()">
          <!-- Language -->
          <div class="fr-settings-section">
            <div class="fr-settings-title" data-i18n="ui.quick_settings.language">Language</div>
            <div class="fr-btn-group">
              <button class="fr-toggle-btn{% if locale == 'en' %} active{% endif %}" data-fr-locale="en">English</button>
              <button class="fr-toggle-btn{% if locale == 'pl' %} active{% endif %}" data-fr-locale="pl">Polski</button>
            </div>
          </div>
          <!-- Theme -->
          <div class="fr-settings-section">
            <div class="fr-settings-title" data-i18n="ui.quick_settings.theme">Theme</div>
            <div class="fr-btn-group">
              <button class="fr-toggle-btn active" data-fr-theme="light" data-i18n="ui.theme.light">Light</button>
              <button class="fr-toggle-btn" data-fr-theme="system" data-i18n="ui.theme.auto">Auto</button>
              <button class="fr-toggle-btn" data-fr-theme="dark" data-i18n="ui.theme.dark">Dark</button>
              <button class="fr-toggle-btn" data-fr-theme="midnight" data-i18n="ui.theme.midnight">Midnight</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<!-- ═══ MAIN CONTENT ═══ -->
<div class="fr-wrapper">
  <!-- Hero -->
  <div class="fr-hero">
    <h1 data-i18n="first_run.title">Welcome to ReleaseBoard</h1>
    <p data-i18n="first_run.subtitle">No configuration file found. Let's set up your first configuration.</p>
    <div class="fr-config-path">
      <span data-i18n="first_run.config_path">Configuration will be saved to:</span>
      <code>{{ config_path }}</code>
    </div>
  </div>

  <!-- Option cards -->
  <div class="fr-cards">

    <!-- Card 1: Start Fresh (recommended) -->
    <div class="fr-card active" data-card="fresh" onclick="selectCard('fresh')">
      <div class="fr-card-header">
        <div class="fr-card-icon fresh">🚀</div>
        <span class="fr-card-title" data-i18n="first_run.start_fresh">Start Fresh</span>
        <span class="fr-badge" data-i18n="first_run.recommended">Recommended</span>
      </div>
      <p class="fr-card-desc" data-i18n="first_run.start_fresh_desc">Create a minimal empty configuration with default layers and no repositories.</p>
      <div class="fr-card-body">
        <div class="fr-form-group">
          <label class="fr-label" for="releaseName" data-i18n="first_run.release_name">Release Name</label>
          <input class="fr-input" type="text" id="releaseName" spellcheck="false">
        </div>
        <div class="fr-row">
          <div class="fr-form-group">
            <label class="fr-label" for="targetMonth" data-i18n="first_run.target_month">Target Month</label>
            <select class="fr-select" id="targetMonth">
              <option value="1" data-i18n="rc.month.jan">January</option>
              <option value="2" data-i18n="rc.month.feb">February</option>
              <option value="3" data-i18n="rc.month.mar">March</option>
              <option value="4" data-i18n="rc.month.apr">April</option>
              <option value="5" data-i18n="rc.month.may">May</option>
              <option value="6" data-i18n="rc.month.jun">June</option>
              <option value="7" data-i18n="rc.month.jul">July</option>
              <option value="8" data-i18n="rc.month.aug">August</option>
              <option value="9" data-i18n="rc.month.sep">September</option>
              <option value="10" data-i18n="rc.month.oct">October</option>
              <option value="11" data-i18n="rc.month.nov">November</option>
              <option value="12" data-i18n="rc.month.dec">December</option>
            </select>
          </div>
          <div class="fr-form-group">
            <label class="fr-label" for="targetYear" data-i18n="first_run.target_year">Target Year</label>
            <input class="fr-input" type="number" id="targetYear" min="2020" max="2099">
          </div>
        </div>
        <div class="fr-form-group">
          <label class="fr-label" for="branchPattern" data-i18n="first_run.branch_pattern">Branch Pattern</label>
          <input class="fr-input" type="text" id="branchPattern" value="release/{YYYY}.{MM}" spellcheck="false">
        </div>
        <button class="fr-btn primary" id="btnCreateFresh" onclick="createFresh()" data-i18n="first_run.create_config">Create Configuration</button>
        <div class="fr-message" id="msgFresh"></div>
      </div>
    </div>

    <!-- Card 2: Prepare Config (wizard — scan repos from GitHub/GitLab) -->
    <div class="fr-card" data-card="wizard" onclick="selectCard('wizard')">
      <div class="fr-card-header">
        <div class="fr-card-icon wizard">🧙</div>
        <span class="fr-card-title" data-i18n="first_run.prepare_config">Prepare Config</span>
      </div>
      <p class="fr-card-desc" data-i18n="first_run.prepare_config_desc">Auto-discover repositories from GitHub or GitLab and build a full configuration with the setup wizard.</p>
      <div class="fr-card-body">
        <p class="fr-hint" data-i18n="first_run.prepare_config_hint">Creates a starter configuration and opens the Prepare Config wizard where you can define layers, scan organizations, and discover repositories automatically.</p>
        <button class="fr-btn primary" id="btnPrepareConfig" onclick="prepareConfig()" data-i18n="first_run.launch_wizard">Launch Wizard</button>
        <div class="fr-message" id="msgWizard"></div>
      </div>
    </div>

    <!-- Card 3: Import from Example -->
    <div class="fr-card" data-card="example" onclick="selectCard('example')">
      <div class="fr-card-header">
        <div class="fr-card-icon example">📋</div>
        <span class="fr-card-title" data-i18n="first_run.import_example">Import from Example</span>
      </div>
      <p class="fr-card-desc" data-i18n="first_run.import_example_desc">Start with a pre-built example configuration.</p>
      <div class="fr-card-body">
        <div class="fr-examples-list" id="examplesList">
          <div class="fr-no-examples" data-i18n="first_run.no_examples">Loading examples...</div>
        </div>
        <button class="fr-btn primary" id="btnUseExample" onclick="useExample()" disabled data-i18n="first_run.use_example">Use This Example</button>
        <div class="fr-message" id="msgExample"></div>
      </div>
    </div>

    <!-- Card 4: Import JSON -->
    <div class="fr-card" data-card="import" onclick="selectCard('import')">
      <div class="fr-card-header">
        <div class="fr-card-icon import">📝</div>
        <span class="fr-card-title" data-i18n="first_run.import_json">Import JSON</span>
      </div>
      <p class="fr-card-desc" data-i18n="first_run.import_json_desc">Paste your own configuration JSON.</p>
      <div class="fr-card-body">
        <div class="fr-form-group">
          <textarea class="fr-textarea" id="importJson" placeholder='{"release": {"name": "...", "target_month": 1, "target_year": 2025}, "repositories": []}'></textarea>
        </div>
        <button class="fr-btn primary" id="btnImportJson" onclick="importJson()" data-i18n="first_run.validate_import">Validate &amp; Import</button>
        <div class="fr-message" id="msgImport"></div>
      </div>
    </div>

  </div>
</div>

<!-- ═══ FOOTER (shared shell — matches dashboard rb-footer) ═══ -->
<footer class="rb-footer">
  <div class="rb-footer-copyright">
    &copy; {{ year }} <a class="rb-footer-author" href="https://polprog.pl/" target="_blank">POLPROG</a>.
    <span data-i18n="ui.footer.all_rights">All rights reserved.</span>
  </div>
  <div class="rb-footer-tools">
    <span data-i18n="ui.footer.built_with">Dashboard built with</span>
    <a class="rb-footer-brand" href="https://github.com/polprog-tech/ReleaseBoard" target="_blank">ReleaseBoard</a>
    v{{ version }}
    &amp;
    <a class="rb-footer-brand" href="https://github.com/polprog-tech/ReleasePilot" target="_blank">ReleasePilot</a>
    {% if rp_version and rp_version != '0.0.0' %}v{{ rp_version }}{% endif %}
  </div>
</footer>

<script>
(function() {
  'use strict';

  /* ── I18N (inline — no dependency on full i18n system) ── */
  var I18N = {
    en: {
      'first_run.title': 'Welcome to ReleaseBoard',
      'first_run.subtitle': "No configuration file found. Let\u2019s set up your first configuration.",
      'first_run.config_path': 'Configuration will be saved to:',
      'first_run.start_fresh': 'Start Fresh',
      'first_run.start_fresh_desc': 'Create a minimal empty configuration with default layers and no repositories.',
      'first_run.prepare_config': 'Prepare Config',
      'first_run.prepare_config_desc': 'Auto-discover repositories from GitHub or GitLab and build a full configuration with the setup wizard.',
      'first_run.prepare_config_hint': 'Creates a starter configuration and opens the Prepare Config wizard where you can define layers, scan organizations, and discover repositories automatically.',
      'first_run.launch_wizard': 'Launch Wizard',
      'first_run.import_example': 'Import from Example',
      'first_run.import_example_desc': 'Start with a pre-built example configuration.',
      'first_run.import_json': 'Import JSON',
      'first_run.import_json_desc': 'Paste your own configuration JSON.',
      'first_run.release_name': 'Release Name',
      'first_run.target_month': 'Target Month',
      'first_run.target_year': 'Target Year',
      'first_run.branch_pattern': 'Branch Pattern',
      'first_run.create_config': 'Create Configuration',
      'first_run.use_example': 'Use This Example',
      'first_run.validate_import': 'Validate & Import',
      'first_run.creating': 'Creating configuration\u2026',
      'first_run.success': 'Configuration created! Redirecting\u2026',
      'first_run.error': 'Error creating configuration',
      'first_run.invalid_json': 'Invalid JSON',
      'first_run.no_examples': 'No example configurations found.',
      'first_run.recommended': 'Recommended',
      'ui.quick_settings.language': 'Language',
      'ui.quick_settings.theme': 'Theme',
      'ui.theme.light': 'Light',
      'ui.theme.auto': 'Auto',
      'ui.theme.dark': 'Dark',
      'ui.theme.midnight': 'Midnight',
      'ui.footer.all_rights': 'All rights reserved.',
      'ui.footer.built_with': 'Dashboard built with',
      'rc.month.jan': 'January',
      'rc.month.feb': 'February',
      'rc.month.mar': 'March',
      'rc.month.apr': 'April',
      'rc.month.may': 'May',
      'rc.month.jun': 'June',
      'rc.month.jul': 'July',
      'rc.month.aug': 'August',
      'rc.month.sep': 'September',
      'rc.month.oct': 'October',
      'rc.month.nov': 'November',
      'rc.month.dec': 'December',
    },
    pl: {
      'first_run.title': 'Witaj w ReleaseBoard',
      'first_run.subtitle': 'Nie znaleziono pliku konfiguracyjnego. Skonfigurujmy Twoje pierwsze ustawienia.',
      'first_run.config_path': 'Konfiguracja zostanie zapisana do:',
      'first_run.start_fresh': 'Zacznij od nowa',
      'first_run.start_fresh_desc': 'Utw\u00f3rz minimaln\u0105 pust\u0105 konfiguracj\u0119 z domy\u015blnymi warstwami, bez repozytori\u00f3w.',
      'first_run.prepare_config': 'Przygotuj konfiguracj\u0119',
      'first_run.prepare_config_desc': 'Automatycznie wykryj repozytoria z GitHub lub GitLab i zbuduj pe\u0142n\u0105 konfiguracj\u0119 za pomoc\u0105 kreatora.',
      'first_run.prepare_config_hint': 'Tworzy pocz\u0105tkow\u0105 konfiguracj\u0119 i otwiera kreator, w kt\u00f3rym mo\u017cesz zdefiniowa\u0107 warstwy, skanowa\u0107 organizacje i automatycznie wykrywa\u0107 repozytoria.',
      'first_run.launch_wizard': 'Uruchom kreator',
      'first_run.import_example': 'Importuj z przyk\u0142adu',
      'first_run.import_example_desc': 'Rozpocznij od gotowej przyk\u0142adowej konfiguracji.',
      'first_run.import_json': 'Importuj JSON',
      'first_run.import_json_desc': 'Wklej w\u0142asn\u0105 konfiguracj\u0119 JSON.',
      'first_run.release_name': 'Nazwa wydania',
      'first_run.target_month': 'Docelowy miesi\u0105c',
      'first_run.target_year': 'Docelowy rok',
      'first_run.branch_pattern': 'Wzorzec ga\u0142\u0119zi',
      'first_run.create_config': 'Utw\u00f3rz konfiguracj\u0119',
      'first_run.use_example': 'U\u017cyj tego przyk\u0142adu',
      'first_run.validate_import': 'Zweryfikuj i importuj',
      'first_run.creating': 'Tworzenie konfiguracji\u2026',
      'first_run.success': 'Konfiguracja utworzona! Przekierowuj\u0119\u2026',
      'first_run.error': 'B\u0142\u0105d tworzenia konfiguracji',
      'first_run.invalid_json': 'Nieprawid\u0142owy JSON',
      'first_run.no_examples': 'Nie znaleziono przyk\u0142adowych konfiguracji.',
      'first_run.recommended': 'Zalecane',
      'ui.quick_settings.language': 'J\u0119zyk',
      'ui.quick_settings.theme': 'Motyw',
      'ui.theme.light': 'Jasny',
      'ui.theme.auto': 'Auto',
      'ui.theme.dark': 'Ciemny',
      'ui.theme.midnight': 'P\u00f3\u0142noc',
      'ui.footer.all_rights': 'Wszelkie prawa zastrze\u017cone.',
      'ui.footer.built_with': 'Dashboard zbudowany z',
      'rc.month.jan': 'Stycze\u0144',
      'rc.month.feb': 'Luty',
      'rc.month.mar': 'Marzec',
      'rc.month.apr': 'Kwiecie\u0144',
      'rc.month.may': 'Maj',
      'rc.month.jun': 'Czerwiec',
      'rc.month.jul': 'Lipiec',
      'rc.month.aug': 'Sierpie\u0144',
      'rc.month.sep': 'Wrzesie\u0144',
      'rc.month.oct': 'Pa\u017adziernik',
      'rc.month.nov': 'Listopad',
      'rc.month.dec': 'Grudzie\u0144',
    }
  };

  var locale = document.documentElement.lang || 'en';
  var catalog = I18N[locale] || I18N['en'];

  /* Build redirect URL preserving the current locale */
  function withLang(url) {
    var u = new URL(url, window.location.origin);
    u.searchParams.set('lang', locale);
    return u.pathname + u.search;
  }

  function getText(key) {
    return catalog[key] || I18N['en'][key] || key;
  }

  /* ── Apply i18n to DOM ── */
  document.querySelectorAll('[data-i18n]').forEach(function(el) {
    var key = el.getAttribute('data-i18n');
    var text = getText(key);
    if (text !== key) el.textContent = text;
  });

  /* ── Theme handling (matches dashboard pattern) ── */
  function setTheme(t) {
    document.documentElement.setAttribute('data-theme', t);
    document.querySelectorAll('[data-fr-theme]').forEach(function(b) {
      b.classList.toggle('active', b.dataset.frTheme === t);
    });
    try { localStorage.setItem('rb-theme', t); } catch(e) {}
  }

  document.querySelectorAll('[data-fr-theme]').forEach(function(b) {
    b.addEventListener('click', function(e) {
      e.stopPropagation();
      setTheme(b.dataset.frTheme);
    });
  });

  // Restore saved theme
  try {
    var saved = localStorage.getItem('rb-theme');
    if (saved) setTheme(saved);
  } catch(e) {}

  /* ── Language switching ── */
  document.querySelectorAll('[data-fr-locale]').forEach(function(b) {
    b.addEventListener('click', function(e) {
      e.stopPropagation();
      var newLocale = b.dataset.frLocale;
      localStorage.setItem('rb_locale', newLocale);
      sessionStorage.setItem('fr_restore_settings', 'true');
      var url = new URL(window.location.href);
      url.searchParams.set('lang', newLocale);
      window.location.href = url.toString();
    });
  });

  /* ── Settings panel toggle ── */
  var settingsOpen = false;
  var settingsWrap = document.getElementById('frSettings');

  window.frToggleSettings = function() {
    settingsOpen = !settingsOpen;
    settingsWrap.classList.toggle('open', settingsOpen);
  };

  document.addEventListener('click', function(e) {
    if (settingsOpen && !e.target.closest('#frSettings')) {
      settingsOpen = false;
      settingsWrap.classList.remove('open');
    }
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && settingsOpen) {
      settingsOpen = false;
      settingsWrap.classList.remove('open');
    }
  });

  /* Restore settings panel after language-change reload */
  if (sessionStorage.getItem('fr_restore_settings') === 'true') {
    sessionStorage.removeItem('fr_restore_settings');
    setTimeout(function() { if (!settingsOpen) frToggleSettings(); }, 50);
  }

  /* ── Form defaults ── */
  var now = new Date();
  var _monthKeys = ['rc.month.jan','rc.month.feb','rc.month.mar','rc.month.apr','rc.month.may','rc.month.jun','rc.month.jul','rc.month.aug','rc.month.sep','rc.month.oct','rc.month.nov','rc.month.dec'];
  var monthNames = _monthKeys.map(function(k){ return getText(k); });
  document.getElementById('releaseName').value = monthNames[now.getMonth()] + ' ' + now.getFullYear() + ' Release';
  document.getElementById('targetMonth').value = String(now.getMonth() + 1);
  document.getElementById('targetYear').value = String(now.getFullYear());

  var selectedExample = null;

  /* ── Load examples ── */
  fetch('/api/examples',{headers:{'X-Requested-With':'XMLHttpRequest'}})
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var list = document.getElementById('examplesList');
      if (!data.ok || !data.examples || data.examples.length === 0) {
        list.innerHTML = '<div class="fr-no-examples">' + getText('first_run.no_examples') + '</div>';
        return;
      }
      list.innerHTML = '';
      data.examples.forEach(function(ex) {
        var item = document.createElement('div');
        item.className = 'fr-example-item';
        item.dataset.name = ex.name;
        item.innerHTML =
          '<span class="fr-example-name">' + esc(ex.title) + ' <span class="fr-example-file">(' + esc(ex.name) + ')</span></span>' +
          '<span class="fr-example-meta">' + ex.repos + ' repos · ' + ex.layers + ' layers</span>';
        item.onclick = function(e) {
          e.stopPropagation();
          list.querySelectorAll('.fr-example-item').forEach(function(i) { i.classList.remove('selected'); });
          item.classList.add('selected');
          selectedExample = ex.name;
          document.getElementById('btnUseExample').disabled = false;
        };
        list.appendChild(item);
      });
    })
    .catch(function() {
      document.getElementById('examplesList').innerHTML = '<div class="fr-no-examples">Failed to load examples.</div>';
    });

  /* ── Card selection ── */
  window.selectCard = function(card) {
    document.querySelectorAll('.fr-card').forEach(function(c) { c.classList.remove('active'); });
    var el = document.querySelector('.fr-card[data-card="' + card + '"]');
    if (el) el.classList.add('active');
  };

  /* ── Create fresh config ── */
  window.createFresh = async function() {
    var btn = document.getElementById('btnCreateFresh');
    var msg = document.getElementById('msgFresh');
    setBtnLoading(btn, true);
    clearMsg(msg);
    try {
      var res = await fetch('/api/config/create', {
        method: 'POST',
        headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
        body: JSON.stringify({
          mode: 'empty',
          release_name: document.getElementById('releaseName').value,
          target_month: parseInt(document.getElementById('targetMonth').value, 10),
          target_year: parseInt(document.getElementById('targetYear').value, 10),
          branch_pattern: document.getElementById('branchPattern').value,
        })
      });
      var data = await res.json();
      if (data.ok && data.redirect) {
        showMsg(msg, 'success', getText('first_run.success'));
        setTimeout(function() { window.location.href = withLang(data.redirect); }, 600);
      } else {
        showMsg(msg, 'error', formatErrors(data));
        setBtnLoading(btn, false);
      }
    } catch(e) {
      showMsg(msg, 'error', getText('first_run.error') + ': ' + e.message);
      setBtnLoading(btn, false);
    }
  };

  /* ── Prepare Config (wizard) ── */
  window.prepareConfig = async function() {
    var btn = document.getElementById('btnPrepareConfig');
    var msg = document.getElementById('msgWizard');
    setBtnLoading(btn, true);
    clearMsg(msg);
    try {
      var res = await fetch('/api/config/create', {
        method: 'POST',
        headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
        body: JSON.stringify({
          mode: 'empty',
          release_name: monthNames[now.getMonth()] + ' ' + now.getFullYear() + ' Release',
          target_month: now.getMonth() + 1,
          target_year: now.getFullYear(),
          branch_pattern: 'release/{YYYY}.{MM}',
        })
      });
      var data = await res.json();
      if (data.ok) {
        showMsg(msg, 'success', getText('first_run.success'));
        setTimeout(function() { window.location.href = withLang('/?open_wizard=1'); }, 600);
      } else {
        showMsg(msg, 'error', formatErrors(data));
        setBtnLoading(btn, false);
      }
    } catch(e) {
      showMsg(msg, 'error', getText('first_run.error') + ': ' + e.message);
      setBtnLoading(btn, false);
    }
  };

  /* ── Use example ── */
  window.useExample = async function() {
    if (!selectedExample) return;
    var btn = document.getElementById('btnUseExample');
    var msg = document.getElementById('msgExample');
    setBtnLoading(btn, true);
    clearMsg(msg);
    try {
      var res = await fetch('/api/config/create', {
        method: 'POST',
        headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
        body: JSON.stringify({ mode: 'example', example: selectedExample })
      });
      var data = await res.json();
      if (data.ok && data.redirect) {
        showMsg(msg, 'success', getText('first_run.success'));
        setTimeout(function() { window.location.href = withLang(data.redirect); }, 600);
      } else {
        showMsg(msg, 'error', formatErrors(data));
        setBtnLoading(btn, false);
      }
    } catch(e) {
      showMsg(msg, 'error', getText('first_run.error') + ': ' + e.message);
      setBtnLoading(btn, false);
    }
  };

  /* ── Import JSON ── */
  window.importJson = async function() {
    var btn = document.getElementById('btnImportJson');
    var msg = document.getElementById('msgImport');
    var raw = document.getElementById('importJson').value.trim();
    clearMsg(msg);
    var parsed;
    try { parsed = JSON.parse(raw); }
    catch(e) {
      showMsg(msg, 'error', getText('first_run.invalid_json') + ': ' + e.message);
      return;
    }
    setBtnLoading(btn, true);
    try {
      var res = await fetch('/api/config/create', {
        method: 'POST',
        headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
        body: JSON.stringify({ mode: 'import', config: parsed })
      });
      var data = await res.json();
      if (data.ok && data.redirect) {
        showMsg(msg, 'success', getText('first_run.success'));
        setTimeout(function() { window.location.href = withLang(data.redirect); }, 600);
      } else {
        showMsg(msg, 'error', formatErrors(data));
        setBtnLoading(btn, false);
      }
    } catch(e) {
      showMsg(msg, 'error', getText('first_run.error') + ': ' + e.message);
      setBtnLoading(btn, false);
    }
  };

  /* ── Helpers ── */
  function esc(s) {
    var d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  function setBtnLoading(btn, loading) {
    if (loading) {
      btn.disabled = true;
      btn.dataset.origText = btn.textContent;
      btn.innerHTML = '<span class="fr-spinner"></span> ' + getText('first_run.creating');
    } else {
      btn.disabled = false;
      btn.textContent = btn.dataset.origText || btn.textContent;
    }
  }

  function showMsg(el, type, text) {
    el.className = 'fr-message ' + type;
    el.textContent = text;
  }

  function clearMsg(el) {
    el.className = 'fr-message';
    el.textContent = '';
  }

  function formatErrors(data) {
    if (data.errors && Array.isArray(data.errors)) return data.errors.join('; ');
    return data.error || getText('first_run.error');
  }
})();
</script>
</body>
</html>
