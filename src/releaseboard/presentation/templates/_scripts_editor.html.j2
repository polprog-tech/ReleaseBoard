  /* ============================================================
     Section Order (template-driven, no drag-and-drop)
     ============================================================ */
  let sectionOrder = null;

  function getDefaultSectionOrder(){
    const sections = document.querySelectorAll('#dashboardContent .dashboard-section');
    return Array.from(sections).map(s=>s.dataset.sectionId).filter(Boolean);
  }

  function initSectionOrder(){
    try {
      const saved = localStorage.getItem('rb-section-order');
      if(saved){ sectionOrder = JSON.parse(saved); applySectionOrder(); }
      else { sectionOrder = getDefaultSectionOrder(); }
    } catch(e){ sectionOrder = getDefaultSectionOrder(); }
  }

  function applySectionOrder(){
    if(!sectionOrder || sectionOrder.length === 0) return;
    const container = document.getElementById('dashboardContent');
    if(!container) return;
    const sections = {};
    container.querySelectorAll('.dashboard-section').forEach(el=>{
      if(el.dataset.sectionId) sections[el.dataset.sectionId] = el;
    });
    const appended = new Set();
    sectionOrder.forEach(id=>{
      if(sections[id]){ container.appendChild(sections[id]); appended.add(id); }
    });
    Object.keys(sections).forEach(id=>{
      if(!appended.has(id)) container.appendChild(sections[id]);
    });
  }

  function saveSectionOrder(){
    const container = document.getElementById('dashboardContent');
    sectionOrder = Array.from(container.querySelectorAll('.dashboard-section')).map(s=>s.dataset.sectionId).filter(Boolean);
    try{ localStorage.setItem('rb-section-order', JSON.stringify(sectionOrder)); }catch(e){}
  }

  /* ============================================================
     Layout Templates
     ============================================================ */
  const PREDEFINED_TEMPLATES = {
    'default': { name: _t('ui.template.default'), order: ['milestones','metrics','filters','attention','layer-*','summary'] },
    'executive': { name: _t('ui.template.executive'), order: ['milestones','metrics','summary'] },
    'release-manager': { name: _t('ui.template.release_manager'), order: ['milestones','attention','filters','layer-*','metrics','summary'] },
    'engineering': { name: _t('ui.template.engineering'), order: ['milestones','filters','layer-*','attention','metrics','summary'] },
    'compact': { name: _t('ui.template.compact'), order: ['milestones','metrics','attention','summary'] },
    'calendar': { name: _t('ui.template.calendar'), order: ['milestones','release-calendar'] },
  };
  let activeTemplate = 'engineering';
  let userTemplates = {};

  function loadTemplates(){
    try{
      const saved = localStorage.getItem('rb-user-templates');
      if(saved) userTemplates = JSON.parse(saved);
      const active = localStorage.getItem('rb-active-template');
      if(active) activeTemplate = active;
    }catch(e){}
    renderTemplateList();
    if(activeTemplate) applyTemplate(activeTemplate);
  }

  function saveUserTemplates(){
    try{
      localStorage.setItem('rb-user-templates', JSON.stringify(userTemplates));
      localStorage.setItem('rb-active-template', activeTemplate);
    }catch(e){}
  }

  function renderTemplateList(){
    const container = document.getElementById('layoutTemplateList');
    if(!container) return;
    let html = '';
    // Predefined
    Object.keys(PREDEFINED_TEMPLATES).forEach(id=>{
      const t = PREDEFINED_TEMPLATES[id];
      const cls = activeTemplate === id ? 'active' : '';
      html += '<button class="layout-template-btn '+cls+'" onclick="RB.applyTemplate(\''+id+'\')">'+esc(t.name)+'</button>';
    });
    // User templates
    Object.keys(userTemplates).forEach(id=>{
      const t = userTemplates[id];
      const cls = activeTemplate === id ? 'active' : '';
      html += '<button class="layout-template-btn '+cls+'" onclick="RB.applyTemplate(\''+id+'\')" oncontextmenu="event.preventDefault();RB.deleteTemplate(\''+id+'\')">'+esc(t.name)+' ✎</button>';
    });
    container.innerHTML = html;
  }

  function applyTemplate(id){
    const template = PREDEFINED_TEMPLATES[id] || userTemplates[id];
    if(!template) return;
    activeTemplate = id;
    // Expand wildcard patterns like 'layer-*' to actual layer section IDs
    const allSections = getDefaultSectionOrder();
    const layerSections = allSections.filter(s=>s.startsWith('layer-'));
    const expanded = [];
    template.order.forEach(pat=>{
      if(pat === 'layer-*'){ layerSections.forEach(l=>expanded.push(l)); }
      else { expanded.push(pat); }
    });
    // Ensure milestones is always included (persistent shared section)
    if(!expanded.includes('milestones') && allSections.includes('milestones')){
      expanded.splice(0, 0, 'milestones');
    }
    sectionOrder = expanded;

    // Hide sections not in template (visibility control)
    const container = document.getElementById('dashboardContent');
    container.querySelectorAll('.dashboard-section').forEach(el=>{
      const sid = el.dataset.sectionId;
      // Never hide milestones or empty-state via template — they're managed by their own init logic
      if(sid === 'milestones' || sid === 'empty-state') return;
      el.classList.toggle('hidden', sid && !expanded.includes(sid));
    });

    applySectionOrder();
    saveSectionOrder();
    saveUserTemplates();
    renderTemplateList();
  }
  function deleteTemplate(id){
    if(!userTemplates[id]) return;
    showModal({
      title: _t('ui.modal.delete_template'),
      desc: _t('ui.modal.confirm_delete_template', {name: esc(userTemplates[id].name)}),
      buttons: [
        { label: _t('ui.delete'), cls: 'danger', onClick: function(){
          closeModal();
          delete userTemplates[id];
          if(activeTemplate === id){ activeTemplate = 'default'; applyTemplate('default'); }
          saveUserTemplates();
          renderTemplateList();
        }},
        { label: _t('ui.cancel'), cls: 'cancel' }
      ]
    });
  }

  /* --- JSON Autocomplete --- */
  let acPopup = null;
  function initJsonAutocomplete(){
    const editor = document.getElementById('jsonEditor');
    if(!editor) return;
    editor.addEventListener('keydown', function(e){
      if(e.key === 'Escape' && acPopup){ hideAcPopup(); e.preventDefault(); return; }
      if(acPopup && (e.key === 'ArrowDown' || e.key === 'ArrowUp')){
        e.preventDefault();
        const items = acPopup.querySelectorAll('.json-autocomplete-item');
        const cur = acPopup.querySelector('.selected');
        let idx = Array.from(items).indexOf(cur);
        if(e.key==='ArrowDown') idx = Math.min(idx+1, items.length-1);
        else idx = Math.max(idx-1, 0);
        items.forEach(it=>it.classList.remove('selected'));
        items[idx]?.classList.add('selected');
        return;
      }
      if(acPopup && e.key === 'Enter'){
        const sel = acPopup.querySelector('.selected');
        if(sel){ e.preventDefault(); insertAcValue(editor, sel.dataset.value); hideAcPopup(); return; }
      }
      if(acPopup && e.key === 'Tab'){
        const sel = acPopup.querySelector('.selected') || acPopup.querySelector('.json-autocomplete-item');
        if(sel){ e.preventDefault(); insertAcValue(editor, sel.dataset.value); hideAcPopup(); return; }
      }
    });
    editor.addEventListener('input', function(){ showAcSuggestions(this); });
    editor.addEventListener('blur', function(){ setTimeout(hideAcPopup, 200); });
  }
  function showAcSuggestions(editor){
    const pos = editor.selectionStart;
    const text = editor.value.substring(0, pos);
    // Detect if we're after a quote that looks like a key position
    const lineStart = text.lastIndexOf('\n') + 1;
    const line = text.substring(lineStart);
    const keyMatch = line.match(/"([a-z_]*)$/i);
    if(!keyMatch){ hideAcPopup(); return; }
    const partial = keyMatch[1].toLowerCase();
    // Determine context: what object are we in?
    const context = detectJsonContext(text);
    const suggestions = getFieldSuggestions(context, partial);
    if(suggestions.length === 0){ hideAcPopup(); return; }
    if(!acPopup){
      acPopup = document.createElement('div');
      acPopup.className = 'json-autocomplete';
      editor.parentElement.appendChild(acPopup);
    }
    acPopup.innerHTML = suggestions.map((s,i)=>
      '<div class="json-autocomplete-item'+(i===0?' selected':'')+'" data-value="'+s.key+'" onmousedown="RB.insertAcFromClick(\''+s.key+'\')"><span class="ac-key">'+s.key+'</span><span class="ac-type">'+s.type+'</span></div>'
    ).join('');
    // Position near cursor
    const rect = editor.getBoundingClientRect();
    const lineNum = text.split('\n').length;
    const lineHeight = 18;
    acPopup.style.top = Math.min(lineNum * lineHeight, rect.height - 50) + 'px';
    acPopup.style.left = (keyMatch.index * 7 + 20) + 'px';
    acPopup.style.display = 'block';
  }
  function hideAcPopup(){ if(acPopup){ acPopup.style.display = 'none'; } }
  function insertAcValue(editor, key){
    const pos = editor.selectionStart;
    const text = editor.value;
    const before = text.substring(0, pos);
    const after = text.substring(pos);
    const keyMatch = before.match(/"([a-z_]*)$/i);
    if(!keyMatch) return;
    const start = pos - keyMatch[1].length;
    editor.value = text.substring(0, start) + key + after;
    editor.selectionStart = editor.selectionEnd = start + key.length;
    editor.dispatchEvent(new Event('input'));
  }
  function insertAcFromClick(key){
    const editor = document.getElementById('jsonEditor');
    if(editor) insertAcValue(editor, key);
    hideAcPopup();
  }
  function detectJsonContext(text){
    // Count open braces/brackets to find context
    let depth = 0; let inArray = false; let lastKey = '';
    for(let i=0;i<text.length;i++){
      if(text[i]==='{') depth++;
      else if(text[i]==='}') depth--;
      else if(text[i]==='[') inArray = true;
      else if(text[i]===']') inArray = false;
    }
    // Find the last key before current position at the right depth
    const keyMatches = [...text.matchAll(/"(\w+)"\s*:/g)];
    if(depth <= 1) return 'root';
    // Find enclosing object key
    let braceCount = 0;
    for(let i = text.length-1; i>=0; i--){
      if(text[i]==='}') braceCount++;
      else if(text[i]==='{'){
        if(braceCount > 0) braceCount--;
        else {
          const before = text.substring(Math.max(0,i-50), i);
          const km = before.match(/"(\w+)"\s*:\s*[\[{]?\s*$/);
          if(km) return km[1];
          break;
        }
      }
    }
    return 'root';
  }
  const SCHEMA_FIELDS = {
    root: [{key:'release',type:'object'},{key:'layers',type:'array'},{key:'repositories',type:'array'},{key:'branding',type:'object'},{key:'settings',type:'object'},{key:'author',type:'object'},{key:'layout',type:'object'}],
    release: [{key:'name',type:'string'},{key:'target_month',type:'int 1-12'},{key:'target_year',type:'int'},{key:'branch_pattern',type:'string'}],
    layers: [{key:'id',type:'string'},{key:'label',type:'string'},{key:'branch_pattern',type:'string'},{key:'color',type:'hex'},{key:'order',type:'int'},{key:'repository_root_url',type:'string'}],
    repositories: [{key:'name',type:'string'},{key:'url',type:'string'},{key:'layer',type:'string'},{key:'branch_pattern',type:'string'},{key:'default_branch',type:'string'},{key:'notes',type:'string'}],
    branding: [{key:'title',type:'string'},{key:'subtitle',type:'string'},{key:'company',type:'string'},{key:'primary_color',type:'hex'},{key:'secondary_color',type:'hex'},{key:'tertiary_color',type:'hex'}],
    settings: [{key:'stale_threshold_days',type:'int'},{key:'output_path',type:'string'},{key:'theme',type:'enum'},{key:'verbose',type:'bool'},{key:'timeout_seconds',type:'int'},{key:'max_concurrent',type:'int'},{key:'repository_root_url',type:'string'}],
    author: [{key:'name',type:'string'},{key:'role',type:'string'},{key:'url',type:'string'},{key:'tagline',type:'string'},{key:'copyright',type:'string'}],
    layout: [{key:'default_template',type:'string'},{key:'section_order',type:'array'},{key:'enable_drag_drop',type:'bool'}],
  };
  function getFieldSuggestions(context, partial){
    const fields = SCHEMA_FIELDS[context] || SCHEMA_FIELDS.root;
    return fields.filter(f => f.key.startsWith(partial));
  }

  /* --- Effective/Active Settings Tab --- */
  function renderEffectiveTab(){
    const c = document.getElementById('effectiveContent');
    if(!c) return;
    const globalBranch = (draft.release && draft.release.branch_pattern) || 'release/{YYYY}.{MM}';
    const globalRoot = (draft.settings && draft.settings.repository_root_url) || '';
    const m = draft.release && draft.release.target_month || 1;
    const y = draft.release && draft.release.target_year || 2025;
    function resolve(pat){ return pat.replace('{YYYY}',y).replace('{YY}',String(y).slice(-2)).replace('{MM}',String(m).padStart(2,'0')).replace('{M}',m); }
    let h = '';
    // Global settings
    h += '<div class="eff-section"><div class="eff-section-title">'+_t('ui.config.effective.global_settings')+'</div><table class="eff-table">';
    h += effRow(_t('ui.config.effective.release_name'), draft.release?.name || '(none)', 'config');
    h += effRow(_t('ui.config.effective.target'), (draft.release?.target_month||'?') + '/' + (draft.release?.target_year||'?'), 'config');
    h += effRow(_t('ui.config.effective.branch_pattern'), globalBranch, draft.release?.branch_pattern ? 'config' : 'default');
    h += effRow(_t('ui.config.effective.resolved_branch'), resolve(globalBranch), 'derived');
    h += effRow(_t('ui.config.effective.root_url'), globalRoot || '(none)', globalRoot ? 'config' : 'default');
    h += effRow(_t('ui.config.effective.stale_threshold'), (draft.settings?.stale_threshold_days||14) + ' days', draft.settings?.stale_threshold_days ? 'config' : 'default');
    h += effRow(_t('ui.config.effective.theme'), draft.settings?.theme || 'system', draft.settings?.theme ? 'config' : 'default');
    h += effRow(_t('ui.config.effective.timeout'), (draft.settings?.timeout_seconds||30) + 's', draft.settings?.timeout_seconds ? 'config' : 'default');
    h += '</table></div>';
    // Layers
    const layers = draft.layers || [];
    if(layers.length > 0){
      h += '<div class="eff-section"><div class="eff-section-title">'+_t('ui.config.effective.layers')+'</div><table class="eff-table">';
      h += '<tr><th>'+_t('ui.config.effective.layer')+'</th><th>'+_t('ui.config.effective.branch_pattern')+'</th><th>'+_t('ui.config.effective.resolved')+'</th><th>'+_t('ui.config.effective.root_url')+'</th><th>'+_t('ui.config.effective.source')+'</th></tr>';
      layers.forEach(l=>{
        const pat = l.branch_pattern || globalBranch;
