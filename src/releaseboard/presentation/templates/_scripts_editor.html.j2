  // ===== Tag Export (YAML) =====
  const _TE_FILENAME_RE = /^[a-zA-Z0-9][a-zA-Z0-9._-]*$/;

  function _teGetFilename() {
    return (document.getElementById('tagExportFilename').value || '').trim();
  }

  function _teBuildYaml(includeNoTag) {
    const repos = Object.values(REPO_DATA);
    const lines = [];
    let included = 0, skipped = 0, total = 0;
    repos.forEach(function(r) {
      if (!r.isGitlab) return;
      total++;
      if (r.latestTag) {
        lines.push(r.name + ':');
        lines.push('  enabled: true');
        lines.push('  AppVersion: ' + r.latestTag);
        lines.push('');
        included++;
      } else if (includeNoTag) {
        lines.push(r.name + ':');
        lines.push('  enabled: false');
        lines.push('  AppVersion: ""');
        lines.push('');
        included++;
      } else {
        skipped++;
      }
    });
    return { yaml: lines.join('\n'), included: included, skipped: skipped, total: total };
  }

  function _tagExportRefresh() {
    var fn = _teGetFilename();
    var errEl = document.getElementById('tagExportFilenameError');
    var dlBtn = document.getElementById('tagExportDownloadBtn');
    var valid = fn.length > 0 && _TE_FILENAME_RE.test(fn);
    errEl.style.display = valid || fn.length === 0 ? 'none' : 'block';
    errEl.textContent = valid ? '' : _t('ui.tag_export.filename_invalid');
    dlBtn.disabled = !valid;

    var incl = document.getElementById('tagExportIncludeNoTag').checked;
    var result = _teBuildYaml(incl);
    document.getElementById('tagExportPreview').textContent = result.yaml || _t('ui.tag_export.no_data');
    var statsEl = document.getElementById('tagExportStats');
    statsEl.innerHTML =
      '<span class="te-stat"><span class="te-stat-value">' + result.total + '</span> ' + _t('ui.tag_export.stat_gitlab') + '</span>' +
      '<span class="te-stat"><span class="te-stat-value">' + result.included + '</span> ' + _t('ui.tag_export.stat_included') + '</span>' +
      (result.skipped > 0 ? '<span class="te-stat"><span class="te-stat-value">' + result.skipped + '</span> ' + _t('ui.tag_export.stat_skipped') + '</span>' : '');
    _teHideStatus();
  }

  function _teShowStatus(msg, isError) {
    var el = document.getElementById('tagExportStatus');
    el.textContent = msg;
    el.className = 'te-status ' + (isError ? 'error' : 'success');
    setTimeout(function() { el.className = 'te-status'; }, 4000);
  }
  function _teHideStatus() {
    document.getElementById('tagExportStatus').className = 'te-status';
  }

  function openTagExport() {
    // Default filename based on current release target
    var input = document.getElementById('tagExportFilename');
    if (!input.value) {
      var now = new Date();
      var y = now.getFullYear();
      var m = String(now.getMonth() + 1).padStart(2, '0');
      input.value = y + '.' + m + '-release';
    }
    document.getElementById('tagExportOverlay').classList.add('active');
    _tagExportRefresh();
    input.focus();
  }

  function closeTagExport() {
    document.getElementById('tagExportOverlay').classList.remove('active');
  }

  function tagExportDownload() {
    var fn = _teGetFilename();
    if (!fn || !_TE_FILENAME_RE.test(fn)) return;
    var incl = document.getElementById('tagExportIncludeNoTag').checked;
    var result = _teBuildYaml(incl);
    if (!result.yaml) { _teShowStatus(_t('ui.tag_export.no_data'), true); return; }
    var blob = new Blob([result.yaml], { type: 'text/yaml' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url;
    a.download = fn + '.yaml';
    a.click();
    URL.revokeObjectURL(url);
    _teShowStatus(_t('ui.tag_export.downloaded'));
  }

  function tagExportCopy() {
    var incl = document.getElementById('tagExportIncludeNoTag').checked;
    var result = _teBuildYaml(incl);
    if (!result.yaml) { _teShowStatus(_t('ui.tag_export.no_data'), true); return; }
    navigator.clipboard.writeText(result.yaml).then(function() {
      _teShowStatus(_t('ui.tag_export.copied'));
    }).catch(function() {
      _teShowStatus(_t('ui.tag_export.copy_failed'), true);
    });
  }

