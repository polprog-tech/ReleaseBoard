  /* --- JSON Editor Validation --- */
  function showJsonParseError(msg){
    const bar = document.getElementById('jsonValBar');
    const okEl = document.getElementById('jsonValOk');
    const errEl = document.getElementById('jsonValErr');
    const countEl = document.getElementById('jsonValCount');
    const listEl = document.getElementById('jsonValErrors');
    okEl.style.display = 'none'; okEl.classList.add('hidden');
    errEl.classList.remove('hidden'); errEl.style.display = '';
    errEl.textContent = '✗ ' + _t('ui.error.json_parse') + ': ' + msg;
    countEl.textContent = '';
    listEl.classList.add('hidden');
    listEl.innerHTML = '';
  }

  async function validateJsonEditor(obj){
    const bar = document.getElementById('jsonValBar');
    const okEl = document.getElementById('jsonValOk');
    const errEl = document.getElementById('jsonValErr');
    const countEl = document.getElementById('jsonValCount');
    const listEl = document.getElementById('jsonValErrors');
    try{
      const res = await fetch('/api/config/validate',{method:'POST',headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},body:JSON.stringify(obj)});
      const data = await res.json();
      const errors = data.errors || [];
      if(errors.length === 0){
        okEl.classList.remove('hidden'); okEl.style.display = '';
        errEl.style.display = 'none'; errEl.classList.add('hidden');
        countEl.textContent = _t('ui.config.effective.top_level_fields',{count:Object.keys(obj).length});
        listEl.classList.add('hidden');
        listEl.innerHTML = '';
      } else {
        okEl.style.display = 'none'; okEl.classList.add('hidden');
        errEl.classList.remove('hidden'); errEl.style.display = '';
        errEl.textContent = '✗ ' + _t('ui.error.validation_count',{count:errors.length});
        countEl.textContent = '';
        listEl.innerHTML = '';
        errors.forEach(function(e){
          const li = document.createElement('li');
          let neatPath = e.loc ? e.loc.join('.') : '';
          if(neatPath.startsWith('body.')) { neatPath = neatPath.substring(5); }
          
          const pathMappings = {
            'release.name': _t('ui.config.release_name', 'Release Name'),
            'release.target_year': _t('ui.config.release_target_year', 'Target Year'),
            'settings.timeout_seconds': _t('ui.config.timeout_seconds', 'Timeout'),
            'settings.max_concurrent': _t('ui.config.max_concurrent', 'Max Concurrent'),
            'settings.stale_threshold_days': _t('ui.config.stale_days', 'Stale Threshold'),
            'settings.repository_root_url': _t('ui.config.repo_root_url', 'Repository Root URL'),
            'branding.primary_color': _t('ui.config.primary_color', 'Primary Color'),
            'settings.output_path': _t('ui.config.output_path', 'Output Path')
          };
          const displayPath = pathMappings[neatPath] || neatPath;
          
          li.textContent = displayPath ? (displayPath + ': ' + e.msg) : e.msg;
          listEl.appendChild(li);
        });
        listEl.classList.remove('hidden');
      }
    }catch(e){
      okEl.style.display = 'none'; okEl.classList.add('hidden');
      errEl.classList.remove('hidden'); errEl.style.display = '';
      errEl.textContent = '✗ ' + _t('ui.error.validation_failed');
      countEl.textContent = '';
      listEl.classList.add('hidden');
    }
  }

  /* --- Effective value validation for auto-derived/inherited --- */
  function validateEffectiveValues(){
    const errors = [];
    // Validate target_year >= current year
    const ty = draft.release && draft.release.target_year;
    if(ty != null && ty < new Date().getFullYear())
      errors.push('release.target_year: '+_t('ui.validation.target_year_past'));
    // Validate layer order >= 0
    (draft.layers||[]).forEach((l,i)=>{
      if(typeof l.order === 'number' && l.order < 0)
        errors.push(`layers.${i}.order: `+_t('ui.validation.order_negative'));
    });
    // Validate repository_root_url format
    const rootUrl = (draft.settings && draft.settings.repository_root_url) || '';
    if(rootUrl && !/^(https?:\/\/|git@|ssh:\/\/|git:\/\/|\/)/.test(rootUrl))
      errors.push('settings.repository_root_url: '+_t('ui.validation.invalid_url'));
    (draft.repositories||[]).forEach((r,i)=>{
      const effUrl = resolveEffectiveUrl(r);
      const effBranch = resolveEffectiveBranch(r);
      if(!r.name && !r.url) errors.push(`repositories.${i}.name: `+_t('ui.validation.name_url_empty'));
      else if(!r.name) errors.push(`repositories.${i}.name: `+_t('ui.validation.name_empty_hint'));
      if(effUrl && !/^(https?:\/\/|git@|ssh:\/\/|git:\/\/|\/)/.test(effUrl) && !effUrl.includes('/'))
        errors.push(`repositories.${i}.url: `+_t('ui.validation.bare_slug'));
    });
    return errors;
  }

  /* --- Validation --- */
  function friendlyError(msg) {
    const map = [
      [/release\.name:.*should be non-empty/, function(){ return _t('ui.validation.release_name_empty'); }],
      [/release\.target_year:.*less than.*minimum/, function(){ return _t('ui.validation.target_year_past'); }],
      [/branding\.secondary_color:.*does not match/, function(){ return _t('ui.validation.secondary_color_invalid'); }],
      [/branding\.primary_color:.*does not match/, function(){ return _t('ui.validation.primary_color_invalid'); }],
      [/settings\.max_concurrent:.*less than.*minimum/, function(){ return _t('ui.validation.max_concurrency'); }],
      [/settings\.stale_threshold_days:.*less than.*minimum/, function(){ return _t('ui.validation.stale_threshold'); }],
      [/settings\.timeout_seconds:.*less than.*minimum/, function(){ return _t('ui.validation.timeout'); }],
      [/settings\.theme:.*is not one of/, function(){ return _t('ui.validation.theme'); }],
      [/repositories\[(\d+)\]\.layer: '([^']+)' is not defined in layers/, function(m){ return _t('ui.validation.layer_not_defined', {index: +m[1]+1, layer: m[2]}); }],
      [/repositories\.(\d+).*url.*should be non-empty/, function(m){ return _t('ui.validation.url_empty', {index: +m[1]+1}); }],
      [/repositories\.(\d+).*name.*should be non-empty/, function(m){ return _t('ui.validation.name_empty', {index: +m[1]+1}); }],
      [/repositories.*should be non-empty/, function(){ return _t('ui.validation.repo_list_empty'); }],
    ];
    for (const [re, repl] of map) {
      const m = msg.match(re);
      if (m) return typeof repl === 'function' ? repl(m) : repl;
    }
    return msg;
  }

  function clearFieldErrors() {
    document.querySelectorAll('.cfg-field-error').forEach(el => el.remove());
    document.querySelectorAll('.cfg-input.has-error, .cfg-select.has-error').forEach(el => el.classList.remove('has-error'));
  }
  function showFieldError(field, msg) {
    field.classList.add('has-error');
    const d = document.createElement('div'); d.className = 'cfg-field-error'; d.textContent = msg;
    const p = field.closest('.cfg-field');
    if(p) p.appendChild(d); else field.insertAdjacentElement('afterend', d);
  }
  function errorToDataPath(e) {
    const i = e.indexOf(':'); if(i<0) return null;
    return e.substring(0,i).trim().replace(/\[(\d+)\]/g,'.$1');
  }
  function placeErrors(errors, panelPrefix) {
    const panel = document.getElementById('validationPanel');
    clearFieldErrors();
    const unmatched = [];
    (errors||[]).forEach(e => {
      const friendly = friendlyError(e), path = errorToDataPath(e);
      
      let inlineDisplay = friendly;
      if (path && inlineDisplay.startsWith(path + ':')) {
        inlineDisplay = inlineDisplay.substring(path.length + 1).trim();
      }
      
      const field = path ? document.querySelector('[data-path="'+CSS.escape(path)+'"]') : null;
      if(field) {
        showFieldError(field, inlineDisplay);
      } else {
        let globalDisplay = friendly;
        if (path && globalDisplay.startsWith(path + ':')) {
           const map = {
             'release.name': _t('ui.config.release_name', 'Release Name'),
             'release.target_year': _t('ui.config.release_target_year', 'Target Year'),
             'settings.timeout_seconds': _t('ui.config.timeout_seconds', 'Timeout (seconds)'),
             'settings.max_concurrent': _t('ui.config.max_concurrent', 'Max Concurrent'),
             'settings.stale_threshold_days': _t('ui.config.stale_days', 'Stale Threshold (days)'),
             'branding.primary_color': _t('ui.config.primary_color', 'Primary Color'),
             'settings.repository_root_url': _t('ui.config.repo_root_url', 'Repository Root URL'),
             'settings.output_path': _t('ui.config.output_path', 'Output Path')
           };
           let baseMsg = globalDisplay.substring(path.length + 1).trim();
           globalDisplay = (map[path] || path) + ': ' + baseMsg;
        }
        unmatched.push(globalDisplay);
      }
    });
    if(unmatched.length) {
      panel.classList.remove('clean');
      const header = panelPrefix || _t('ui.validation.errors_found');
      panel.innerHTML = '<div style="font-weight:600;margin-bottom:4px;color:var(--primary);">'+esc(header)+'</div>' +
        '<ul class="validation-error-list">'+unmatched.map(e=>'<li>'+esc(e)+'</li>').join('')+'</ul>';
      panel.scrollIntoView({behavior:'smooth',block:'nearest'});
    } else { panel.innerHTML=''; panel.classList.add('clean'); }
    _updateActionButtons((errors||[]).length > 0, errors);
  }
  function showSaveErrors(errors) { placeErrors(errors, _t('ui.error.save_failed')); }

  function _updateActionButtons(hasErrors, errors) {
    var applyBtn = document.getElementById('btnApplyConfig');
    var saveBtn = document.getElementById('btnSaveConfig');
    if(applyBtn) {
      applyBtn.disabled = hasErrors;
      if(hasErrors && errors && errors.length) {
        applyBtn.title = _t('ui.validation.fix_errors_hint') + ' (' + errors.length + ')';
      } else {
        applyBtn.title = '';
      }
    }
    if(saveBtn) {
      saveBtn.disabled = hasErrors;
      if(hasErrors && errors && errors.length) {
        saveBtn.title = _t('ui.validation.fix_errors_hint') + ' (' + errors.length + ')';
      } else {
        saveBtn.title = '';
      }
    }
  }

  async function validateDraft(){
    const cleaned = JSON.stringify(cleanDraft(draft));
    const [valRes] = await Promise.all([
      fetch('/api/config/validate',{method:'POST',headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},body:cleaned}),
      fetch('/api/config',{method:'PUT',headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},body:cleaned})
    ]);
    const data = await valRes.json();
    validationErrors = data.errors || [];
    const allErrors = validationErrors.concat(validateEffectiveValues());
    if(allErrors.length > 0){ placeErrors(allErrors, null); }
    else {
      clearFieldErrors();
      const panel = document.getElementById('validationPanel');
      panel.classList.remove('clean');
      panel.innerHTML = '<div class="validation-ok">✓ '+esc(_t('ui.validation.config_valid'))+'</div>';
      _updateActionButtons(false, []);
    }
    const stRes = await fetch('/api/config',{headers:{'X-Requested-With':'XMLHttpRequest'}});
    const stData = await stRes.json();
    updateUnsavedBadge(stData.has_unsaved_changes);
  }

  let _hasUnsavedChanges = false;
  function updateUnsavedBadge(hasChanges){
    _hasUnsavedChanges = hasChanges;
    const badge = document.getElementById('unsavedBadge');
    if(badge) badge.classList.toggle('hidden', !hasChanges);
    const drawerBadge = document.getElementById('drawerDraftBadge');
    if(drawerBadge) drawerBadge.classList.toggle('hidden', !hasChanges);
  }
  function hasUnsavedChanges(){ return _hasUnsavedChanges; }

  /* --- Config actions --- */
  async function applyConfig(){
    if(currentTab==='form') readForm();
    else if(currentTab==='json'){
      try { draft = JSON.parse(document.getElementById('jsonEditor').value); } catch(e){
        showSaveErrors([_t('validation.invalid_json','Invalid JSON syntax')]);
        return;
      }
    }
    try {
      const r1 = await fetch('/api/config',{method:'PUT',headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},body:JSON.stringify(cleanDraft(draft))});
      if(!r1.ok){ showSaveErrors([_t('validation.save_failed','Failed to update configuration')]); return; }
      const r2 = await fetch('/api/config/save',{method:'POST',headers:{'X-Requested-With':'XMLHttpRequest'}});
      const d2 = await r2.json();
      if(!d2.ok){ showSaveErrors(d2.errors||[_t('validation.save_failed','Save failed')]); return; }
      closeDrawer();
      await startAnalysis();
    } catch(e){
      showSaveErrors([_t('validation.network_error','Network error — check connection')]);
    }
  }

  async function saveConfig(){
    if(currentTab==='form') readForm();
    else if(currentTab==='json'){
      try { draft = JSON.parse(document.getElementById('jsonEditor').value); } catch(e){
        showSaveErrors([_t('validation.invalid_json','Invalid JSON syntax')]);
        return;
      }
    }
    try {
      await fetch('/api/config',{method:'PUT',headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},body:JSON.stringify(cleanDraft(draft))});
      const res = await fetch('/api/config/save',{method:'POST',headers:{'X-Requested-With':'XMLHttpRequest'}});
      const data = await res.json();
      if(data.ok){
        updateUnsavedBadge(false);
        window.location.href = window.location.pathname + '?t=' + Date.now();
      } else {
        showSaveErrors(data.errors);
      }
    } catch(e){
      showSaveErrors([_t('validation.network_error','Network error — check connection')]);
    }
  }

  async function resetConfig(){
    const res = await fetch('/api/config/reset',{method:'POST',headers:{'X-Requested-With':'XMLHttpRequest'}});
    const data = await res.json();
    if(data.ok){
      draft = data.draft;
      populateForm();
      updateJsonEditor();
