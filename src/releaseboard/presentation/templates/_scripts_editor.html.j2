        const branchSrc = r.branch_pattern ? 'repo' : (layer && layer.branch_pattern ? 'layer' : 'global');
        const urlSrc = (r.url && /^(https?:\/\/|git@|ssh:\/\/)/.test(r.url)) ? 'repo' : ((layer?.repository_root_url || globalRoot) ? 'derived' : 'repo');
        const nameSrc = r._autoName ? 'derived' : 'config';
