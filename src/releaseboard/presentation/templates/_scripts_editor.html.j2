        h += '<tr><td class="eff-key">' + esc(l.label||l.id) + '</td><td class="eff-val">' + esc(pat) + '</td><td class="eff-val">' + esc(resolve(pat)) + '</td><td class="eff-val">' + esc(root) + '</td><td><span class="eff-source '+src+'">' + src + '</span> <span class="eff-source '+rootSrc+'">' + rootSrc + '</span></td></tr>';
      });
