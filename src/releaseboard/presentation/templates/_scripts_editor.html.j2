  async function handleConfigImportFile(event) {
    const file = (event.target && event.target.files) ? event.target.files[0] : null;
    if (!file) return;
    const status = document.getElementById('cfgImportStatus');
    const actions = document.getElementById('cfgImportActions');

    if (!file.name.endsWith('.json')) {
      status.innerHTML = '<div class="rc-validation-msg error rc-validation-msg-block">' + esc(_t('ui.config_import.wrong_format')) + '</div>';
      status.style.display = '';
      actions.style.display = 'none';
      return;
    }

    status.innerHTML = '<div class="rc-validation-msg rc-validation-msg-block" style="color:var(--text-secondary);">⏳ ' + esc(_t('ui.config_import.validating')) + '</div>';
    status.style.display = '';
    actions.style.display = 'none';

    try {
      const text = await file.text();
      let parsed;
      try {
        parsed = JSON.parse(text);
      } catch (parseErr) {
        status.innerHTML = '<div class="rc-validation-msg error rc-validation-msg-block">❌ ' + esc(_t('ui.config_import.parse_error')) + '</div>';
        return;
      }

      const res = await fetch('/api/config/validate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify(parsed)
      });
      const result = await res.json();

      if (result.ok) {
        _cfgImportData = parsed;
        // Hide dropzone and initial UI after successful validation
        const dz = document.getElementById('cfgImportDropzone'); if (dz) dz.style.display = 'none';
        document.querySelectorAll('.cfgImportInitial').forEach(function(el) { el.style.display = 'none'; });
        // Build import summary
        const repos = (parsed.repositories || []);
        const relName = (parsed.release && parsed.release.name) || '';
        const layers = (parsed.layers || []);
        let summaryParts = [];
        if (relName) summaryParts.push('<strong>' + esc(relName) + '</strong>');
        if (repos.length) summaryParts.push(repos.length + ' repo' + (repos.length !== 1 ? 's' : ''));
        if (layers.length) summaryParts.push(layers.length + ' layer' + (layers.length !== 1 ? 's' : ''));
        const fileLabel = '<div style="margin-top:8px;font-size:1.05em;">\ud83d\udcc4 <strong>' + esc(file.name) + '</strong></div>';
        const summaryLine = summaryParts.length ? '<div style="margin-top:4px;color:var(--text-secondary);">' + summaryParts.join(' · ') + '</div>' : '';
        status.innerHTML = '<div class="rc-validation-msg success rc-validation-msg-block" style="padding:16px;">✅ '
          + esc(_t('ui.config_import.valid'))
          + fileLabel + summaryLine
          + '<div style="margin-top:8px;font-size:.9em;color:var(--text-tertiary);">'
          + esc(_t('ui.config_import.ready_hint') !== 'ui.config_import.ready_hint' ? _t('ui.config_import.ready_hint') : 'File is valid. Choose an action below to apply it.')
          + '</div></div>';
        actions.style.display = '';
      } else {
        _cfgImportData = null;
        let html = '<div class="rc-validation-msg error rc-validation-msg-block">❌ <strong>' + esc(_t('ui.config_import.invalid')) + '</strong>';
        if (result.errors && result.errors.length > 0) {
          html += '<ul class="rc-import-error-list">';
          result.errors.forEach(function(e) { html += '<li>' + esc(e) + '</li>'; });
          html += '</ul>';
        }
        html += '</div>';
        status.innerHTML = html;
        actions.style.display = 'none';
      }
    } catch (err) {
      status.innerHTML = '<div class="rc-validation-msg error rc-validation-msg-block">❌ ' + esc(_t('ui.config_import.error')) + '</div>';
      actions.style.display = 'none';
    }
    if (event.target) event.target.value = '';
  }

