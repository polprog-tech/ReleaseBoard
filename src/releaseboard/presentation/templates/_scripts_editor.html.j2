  function discardConfigPreview() {
    var backup = _cfgPreviewBackup;
    if (!backup) { try { backup = JSON.parse(sessionStorage.getItem('rb-preview-backup')); } catch(e) {} }
    if (backup) {
      draft = backup; _cfgPreviewBackup = null; populateForm(); updateJsonEditor();
      (async function() {
        try { await fetch('/api/config',{method:'PUT',headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},body:JSON.stringify(cleanDraft(draft))}); await fetch('/api/config/save',{method:'POST',headers:{'X-Requested-With':'XMLHttpRequest'}}); } catch(e) {}
        try { sessionStorage.removeItem('rb-preview-backup'); sessionStorage.removeItem('rb-preview-active'); } catch(e) {}
        hidePreviewBadge(); await startAnalysis();
      })();
    } else { hidePreviewBadge(); }
  }
  function showPreviewBadge() { var el = document.getElementById('previewBadge'); if (el) el.classList.remove('hidden'); }
  function hidePreviewBadge() { var el = document.getElementById('previewBadge'); if (el) el.classList.add('hidden'); _cfgPreviewBackup = null; try { sessionStorage.removeItem('rb-preview-backup'); sessionStorage.removeItem('rb-preview-active'); } catch(e) {} }
