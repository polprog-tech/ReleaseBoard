      h += '<div class="eff-section"><div class="eff-section-title">'+_t('ui.config.effective.repositories')+' (' + repos.length + ')</div><table class="eff-table">';
      h += '<tr><th>'+_t('ui.config.effective.name')+'</th><th>'+_t('ui.config.effective.layer')+'</th><th>'+_t('ui.config.effective.effective_url')+'</th><th>'+_t('ui.config.effective.effective_branch')+'</th><th>'+_t('ui.config.effective.sources')+'</th></tr>';
      repos.forEach(r=>{
        const layer = layers.find(l=>l.id===r.layer);
        const effUrl = resolveEffectiveUrl(r);
