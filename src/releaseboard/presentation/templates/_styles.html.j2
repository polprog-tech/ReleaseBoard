.metric-card.missing::before { background: #c52a2a; } .metric-card.missing .metric-value { color: #c52a2a; } .metric-card.missing .metric-icon { background: #fce8e8; color: #c52a2a; }
.metric-card.invalid::before { background: #b8860b; } .metric-card.invalid .metric-value { color: #b8860b; } .metric-card.invalid .metric-icon { background: #fdf4e3; color: #b8860b; }
.metric-card.stale::before { background: #7c3aed; } .metric-card.stale .metric-value { color: #7c3aed; } .metric-card.stale .metric-icon { background: #f0ebfe; color: #7c3aed; }
.metric-card.warning::before { background: #d49200; } .metric-card.warning .metric-value { color: #d49200; } .metric-card.warning .metric-icon { background: #fef8e7; color: #d49200; }
.metric-card.error::before { background: #d93636; } .metric-card.error .metric-value { color: #d93636; } .metric-card.error .metric-icon { background: #fce8e8; color: #d93636; }
