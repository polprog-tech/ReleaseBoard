  .env-timeline { flex-direction: column; align-items: stretch; }
  .env-connector { width: 2px; height: 16px; margin: 0 auto; }
  .env-connector::after { right: auto; bottom: -4px; top: auto; left: 50%; transform: translateX(-50%); border: 5px solid transparent; border-top: 6px solid var(--border); border-left: none; }
  .env-connector.filled::after { border-top-color: var(--primary); border-left-color: transparent; }
  .env-step { padding: 6px 10px; }
}
/* ===== Wizard Modal ===== */
.wizard-overlay {
  position: fixed; inset: 0; z-index: 2000;
  background: rgba(0,0,0,.55);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; pointer-events: none; transition: opacity .25s;
}
.wizard-overlay.open { opacity: 1; pointer-events: auto; }
.wizard-panel {
  background: var(--bg-primary); border-radius: 16px;
  width: min(880px, 94vw); max-height: 96vh;
  display: flex; flex-direction: column;
  box-shadow: 0 24px 64px rgba(0,0,0,.3);
  overflow: hidden;
}
.wizard-header {
  padding: 20px 24px 16px; border-bottom: 1px solid var(--border);
  display: flex; align-items: center; gap: 16px;
}
.wizard-header h2 { margin: 0; font-size: 1.15rem; font-weight: 700; flex: 1; }
.wizard-close {
  background: none; border: none; font-size: 1.3rem;
  cursor: pointer; color: var(--text-tertiary); padding: 4px 8px; border-radius: 6px;
}
.wizard-close:hover { background: var(--bg-secondary); color: var(--text-primary); }
/* Steps indicator */
.wizard-steps {
  display: flex; gap: 0; padding: 0 24px; background: var(--bg-secondary);
  border-bottom: 1px solid var(--border); overflow-x: auto; -webkit-overflow-scrolling: touch; flex-shrink: 0; min-height: 48px;
}
.wizard-step-tab {
  padding: 12px 18px; font-size: .82rem; font-weight: 600;
  color: var(--text-tertiary); border-bottom: 2.5px solid transparent;
  cursor: default; white-space: nowrap; transition: color .2s, border-bottom-color .2s;
}
.wizard-step-tab.active { color: var(--primary); border-bottom-color: var(--primary); }
.wizard-step-tab.done { color: var(--success); }
.wizard-step-tab .step-num {
  display: inline-flex; align-items: center; justify-content: center;
  width: 22px; height: 22px; border-radius: 50%;
  background: var(--bg-tertiary); color: var(--text-tertiary);
  font-size: .72rem; font-weight: 700; margin-right: 6px;
}
.wizard-step-tab.active .step-num { background: var(--primary); color: var(--text-inverse); }
.wizard-step-tab.done .step-num { background: var(--success); color: var(--text-inverse); }
/* Body & steps content */
.wizard-body { flex: 1; overflow-y: auto; padding: 24px; }
.wizard-step-content { display: none; }
.wizard-step-content.active { display: block; }
/* Footer */
.wizard-footer {
  padding: 16px 24px; border-top: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-shrink: 0;
}
.wizard-footer .wiz-btn {
  padding: 8px 20px; border-radius: 8px; font-size: .85rem;
  font-weight: 600; cursor: pointer; border: 1px solid var(--border);
  background: var(--bg-secondary); color: var(--text-primary); transition: background-color .15s, color .15s, border-color .15s;
}
.wizard-footer .wiz-btn:not(.primary):hover { background: var(--bg-hover); }
.wizard-footer .wiz-btn.primary {
  background: var(--primary); color: var(--text-inverse); border-color: var(--primary);
}
.wizard-footer .wiz-btn.primary:hover { filter: brightness(1.1); }
.wizard-footer .wiz-btn:disabled { opacity: .45; pointer-events: none; }
/* Layer editor (step 1) */
.wiz-layer-list { display: flex; flex-direction: column; gap: 12px; }
.wiz-layer-card {
  border: 1px solid var(--border); border-radius: 10px;
  padding: 16px; background: var(--bg-secondary);
}
.wiz-layer-card .wlc-head {
  display: flex; align-items: center; gap: 10px; margin-bottom: 12px;
}
.wiz-layer-card .wlc-badge {
  display: inline-flex; align-items: center; gap: 6px;
  font-weight: 700; font-size: .9rem;
}
.wiz-layer-card .wlc-color {
  width: 14px; height: 14px; border-radius: 50%; border: 2px solid var(--border);
}
.wiz-layer-card .wlc-remove {
  margin-left: auto; background: none; border: none;
  color: var(--text-tertiary); cursor: pointer; font-size: 1.1rem; padding: 2px 6px;
}
.wiz-layer-card .wlc-remove:hover { color: #dc2626; }
.wiz-layer-card .wlc-fields {
  display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
}
.wiz-layer-card .wlc-fields label {
  font-size: .75rem; font-weight: 600; color: var(--text-secondary);
  margin-bottom: 3px; display: block;
}
.wiz-layer-card .wlc-fields input {
  width: 100%; padding: 7px 10px; border: 1px solid var(--border);
  border-radius: 6px; font-size: .85rem; background: var(--bg-primary);
  color: var(--text-primary); box-sizing: border-box;
}
.wiz-layer-card .wlc-url-row { grid-column: 1 / -1; }
.wiz-add-layer {
  padding: 10px; border: 2px dashed var(--border); border-radius: 10px;
  background: none; color: var(--text-tertiary); cursor: pointer;
  font-size: .85rem; font-weight: 600; text-align: center; width: 100%;
}
.wiz-add-layer:hover { border-color: var(--primary); color: var(--primary); }
/* Provider switcher */
.wiz-provider-btn { background: var(--bg-secondary); color: var(--text-secondary); }
.wiz-provider-btn:hover { background: var(--bg-hover); }
.wiz-provider-btn.active { background: var(--primary); color: var(--text-inverse); }
/* Scanning progress (step 2) */
.wiz-scan-area { display: flex; flex-direction: column; gap: 16px; }
.wiz-scan-layer {
  border: 1px solid var(--border); border-radius: 10px;
  padding: 14px 16px; background: var(--bg-secondary);
}
.wiz-scan-layer .wsl-head {
  display: flex; align-items: center; gap: 8px;
  font-weight: 600; font-size: .9rem; margin-bottom: 8px;
}
.wiz-scan-layer .wsl-status {
  font-size: .78rem; color: var(--text-tertiary);
}
.wiz-scan-layer .wsl-bar {
  height: 4px; background: var(--bg-tertiary); border-radius: 4px;
  overflow: hidden; margin-top: 6px;
}
.wiz-scan-layer .wsl-bar-fill {
  height: 100%; border-radius: 4px;
  background: var(--primary); transition: width .4s;
}
@keyframes wiz-pulse {
  0%,100% { opacity: .4; } 50% { opacity: 1; }
}
.wiz-scanning-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--primary); animation: wiz-pulse 1s infinite;
}
/* Review table (step 3) */
.wiz-review-table {
  width: 100%; border-collapse: collapse; font-size: .82rem;
}
.wiz-review-table th {
  text-align: left; padding: 8px 10px; font-weight: 600; font-size: .75rem;
  color: var(--text-tertiary); border-bottom: 2px solid var(--border);
  text-transform: uppercase; letter-spacing: .04em;
}
.wiz-review-table td {
  padding: 7px 10px; border-bottom: 1px solid var(--border);
  vertical-align: middle;
}
.wiz-review-table tr:hover td { background: var(--bg-secondary); }
.wiz-review-table input[type="text"] {
  width: 100%; padding: 5px 8px; border: 1px solid var(--border);
  border-radius: 5px; font-size: .82rem; background: var(--bg-primary);
  color: var(--text-primary); box-sizing: border-box;
}
.wiz-review-table input[type="checkbox"] { width: 16px; height: 16px; cursor: pointer; }
.wiz-review-layer-badge {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 2px 8px; border-radius: 10px; font-size: .75rem;
  font-weight: 600; background: var(--bg-tertiary); white-space: nowrap;
}
.wiz-review-layer-dot { width: 8px; height: 8px; border-radius: 50%; }
.wiz-review-warn { color: #b45309; font-size: .78rem; }
.wiz-review-summary {
  display: flex; gap: 16px; margin-bottom: 16px; flex-wrap: wrap;
}
.wiz-review-stat {
  padding: 8px 14px; border-radius: 8px; background: var(--bg-secondary);
  border: 1px solid var(--border); font-size: .82rem;
}
.wiz-review-stat strong { font-size: 1.1rem; margin-right: 4px; }
/* Confirm step (step 4) */
.wiz-confirm-box {
  text-align: center; padding: 24px; border-radius: 12px;
  background: var(--bg-secondary); border: 1px solid var(--border);
}
.wiz-confirm-box h3 { margin: 0 0 8px; font-size: 1.1rem; }
.wiz-confirm-box p { margin: 0 0 20px; color: var(--text-secondary); font-size: .9rem; }
.wiz-confirm-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
.wiz-confirm-actions .wiz-btn {
  padding: 10px 24px; border-radius: 8px; font-size: .88rem;
  font-weight: 600; cursor: pointer; border: 1px solid var(--border);
  background: var(--bg-secondary); color: var(--text-primary); transition: background-color .15s, color .15s, border-color .15s;
}
.wiz-confirm-actions .wiz-btn.primary {
  background: var(--primary); color: var(--text-inverse); border-color: var(--primary);
}
.wiz-confirm-actions .wiz-btn.primary:hover { filter: brightness(1.1); }
.wiz-confirm-actions .wiz-btn:not(.primary):hover { background: var(--bg-hover); }
.wiz-warnings { margin-top: 16px; padding: 12px 16px; border-radius: 8px; background: #fef3c7; border: 1px solid #fbbf24; font-size: .82rem; color: #92400e; text-align: left; }
.wiz-warnings ul { margin: 6px 0 0 16px; padding: 0; }
.wiz-inline-error, .cfg-save-error { margin-top: 12px; padding: 10px 14px; border-radius: 8px; background: #fef2f2; border: 1px solid #fca5a5; color: #DC2626; font-size: .84rem; line-height: 1.5; }
.wiz-inline-error ul { margin: 4px 0 0 16px; padding: 0; list-style: disc; }
.wiz-field-error { font-size: .75rem; color: #DC2626; margin-top: 4px; font-weight: 500; }
.wizard-overlay input.has-error, .wizard-overlay select.has-error { border-color: #DC2626 !important; box-shadow: 0 0 0 2px #dc262633 !important; }

/* ===== Tag Export Modal ===== */
.te-filename-row { display: flex; align-items: center; gap: 0; }
.te-filename-row .rc-input { border-top-right-radius: 0; border-bottom-right-radius: 0; flex: 1; }
.te-filename-ext { display: flex; align-items: center; padding: 8px 12px; background: var(--bg-secondary); border: 1.5px solid var(--border); border-left: none; border-radius: 0 8px 8px 0; font-size: .88rem; font-weight: 600; color: var(--text-tertiary); white-space: nowrap; }
.te-toggle-row { display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: .88rem; color: var(--text-secondary); }
.te-toggle-row input[type="checkbox"] { width: 16px; height: 16px; accent-color: var(--primary); cursor: pointer; }
.te-stats { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 12px; font-size: .82rem; color: var(--text-tertiary); }
.te-stats .te-stat { display: flex; align-items: center; gap: 4px; }
.te-stats .te-stat-value { font-weight: 700; color: var(--text-primary); }
.te-yaml-preview { background: var(--bg-secondary); border: 1.5px solid var(--border); border-radius: 8px; padding: 16px; font-size: .82rem; font-family: 'SF Mono', 'Consolas', 'Monaco', monospace; line-height: 1.6; overflow: auto; max-height: 340px; white-space: pre; color: var(--text-primary); margin: 0; }
.te-status { margin-top: 12px; font-size: .82rem; font-weight: 600; text-align: center; padding: 6px; border-radius: 6px; display: none; }
.te-status.success { display: block; background: #dcfce7; color: #166534; }
.te-status.error { display: block; background: #fef2f2; color: #DC2626; }
[data-theme="dark"] .te-status.success, [data-theme="midnight"] .te-status.success { background: #052e16; color: #86efac; }
[data-theme="dark"] .te-status.error, [data-theme="midnight"] .te-status.error { background: #450a0a; color: #fca5a5; }
