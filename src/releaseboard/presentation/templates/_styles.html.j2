.row-action-btn { display: inline-flex; align-items: center; gap: 4px; padding: 3px 8px; border-radius: 4px; font-size: 11px; font-weight: 500; cursor: pointer; border: 1px solid var(--border); background: var(--bg-card); color: var(--text-secondary); transition: background-color var(--transition), color var(--transition), border-color var(--transition), box-shadow var(--transition); font-family: var(--font); white-space: nowrap; }
